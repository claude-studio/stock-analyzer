# Database (기존 boj-postgres에 stock_analysis DB 추가)
POSTGRES_DSN=postgresql+asyncpg://stock:stock_pass@boj-postgres:5432/stock_analysis

# Redis
REDIS_URL=redis://stock-redis:6379/0

# Claude Code CLI
CLAUDE_PATH=/usr/bin/claude
CLAUDE_TIMEOUT=120

# DART 공시 API (https://opendart.fss.or.kr)
DART_API_KEY=

# Teams Webhook (수집 실패 알림)
TEAMS_WEBHOOK_URL=

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API Key (빈 값 = 인증 비활성화, 개발 모드)
API_KEY=

# 서버 모드
MODE=PRD

# 관심 종목 (쉼표 구분)
KR_WATCHLIST=005930,000660,035420,035720,051910,006400,068270,105560,055550,003670
US_WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL
